{
  "name": "cc-mobile",
  "private": true,
  "workspaces": [
    "relay",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n relay,web -c cyan,green \"npm run dev -w relay\" \"npm run dev -w web\"",
    "dev:relay": "npm run dev -w relay",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web",
    "start:node": "npm run start -w relay",
    "start": "./start.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}